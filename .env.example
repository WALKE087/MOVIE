# TMDB API Configuration
# Usa tu Access Token (v4 - Bearer Token) o API Key (v3)
# Si empieza con "eyJ" es un Bearer Token y se usará en header Authorization
NEXT_PUBLIC_TMDB_API_KEY=tu_access_token_o_api_key_aqui
NEXT_PUBLIC_TMDB_BASE_URL=https://api.themoviedb.org/3
NEXT_PUBLIC_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
NEXT_PUBLIC_TMDB_IMAGE_SIZE_POSTER=w500
NEXT_PUBLIC_TMDB_IMAGE_SIZE_BACKDROP=w1280

# Video Streaming APIs
NEXT_PUBLIC_VIDSRC_BASE_URL=https://vidsrc.to/embed/movie
NEXT_PUBLIC_VIDLINK_BASE_URL=https://vidlink.pro/movie

# Backend URL (FastAPI)
# URL del backend para autenticación y favoritos
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
